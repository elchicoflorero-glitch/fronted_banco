{
  "name": "banco-peru-frontend",
  "version": "1.0.0",
  "description": "BancoPeru Banking System Frontend - Next.js 15+ with React 19+ and TypeScript",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css}\"",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf .next dist node_modules"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "clsx": "^2.1.1",
    "next": "^15.1.3",
    "react": "^19.0.0-rc-66cd6a0d-20241021",
    "react-dom": "^19.0.0-rc-66cd6a0d-20241021",
    "react-hook-form": "^7.51.5",
    "typescript": "^5.6.3",
    "zod": "^3.22.4",
    "tailwindcss": "^3.4.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47"
  },
  "devDependencies": {
    "@types/node": "^22.9.1",
    "@types/react": "^19.0.0-rc.1",
    "@types/react-dom": "^19.0.0-rc.1",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "eslint": "^9.14.0",
    "eslint-config-next": "^15.1.3",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.3.3"
  }
}
