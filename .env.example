# Frontend API Configuration
# Backend API endpoint that the frontend will communicate with
# In development, this should point to the backend running on localhost
# In production, this should point to your production backend API
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# Environment Configuration
# Set to: development, production, or staging
NODE_ENV="development"

# Frontend Application Metadata
# Application name for display purposes
NEXT_PUBLIC_APP_NAME="BancoPeru"
# Application version
NEXT_PUBLIC_APP_VERSION="1.0.0"

# API Request Configuration
# Request timeout in milliseconds
NEXT_PUBLIC_API_TIMEOUT="30000"
# Number of times to retry failed API requests
NEXT_PUBLIC_API_RETRIES="3"
